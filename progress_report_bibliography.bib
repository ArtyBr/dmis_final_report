
@article{bouziane_real-time_2025,
    title = {Real-time lane detection system using {OpenCV} and {Kalman} filter-based path prediction},
    volume = {6},
    issn = {2707-8213},
    url = {https://www.mechanicaljournals.com/ijae/archives/2025.v6.i1.A.51},
    abstract = {The increasing demand for driver assistance systems and autonomous vehicles has fueled research in real-time lane detection techniques that ensure vehicle positioning and safety. Traditional lane detection algorithms suffer from instability under real-world driving conditions such as poor illumination, occlusions, curved roads, and lane departures. This paper proposes a robust and real-time lane detection system utilizing OpenCV for image processing and computer vision operations, combined with a Kalman Filter for path prediction and lane tracking. The system captures live video frames, processes them using edge detection, region of interest (ROI) masking, and Hough Line Transform to detect lane markers. A Kalman Filter is then employed to smooth lane trajectories and predict the likely path in cases of occlusion or temporary lane loss. The proposed method was tested under varying environmental conditions on standard video datasets and in live driving scenarios. Results demonstrate improved accuracy, reduced jitter, and enhanced predictive reliability compared to static detection models, highlighting the method’s viability for real-time autonomous vehicle applications.},
    language = {en},
    number = {1},
    urldate = {2026-01-02},
    journal = {International Journal of Automobile Engineering},
    author = {Bouziane, Amal and Rami, Salma},
    year = {2025},
    note = {Publisher: AkiNik Publications},
    pages = {52--58},
}

